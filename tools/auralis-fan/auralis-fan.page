<?php
$BASE = "/boot/config/plugins/auralis-fan";
$CONF = "$BASE/fan.conf";
$cfg  = ['MODE'=>'observe','INTERVAL'=>5,'DEADBAND'=>6,'GPU_CRIT'=>87,'CPU_CRIT'=>88,'DISK_CRIT'=>48,'NVME_CRIT'=>78];
$chan = [];
for($i=1;$i<=5;$i++) $chan[$i] = ['src'=>'max','curve'=>'45:70 60:120 72:185 83:255','floor'=>60];
if(is_readable($CONF)){
  foreach(file($CONF) as $l){
    $l = trim(preg_replace('/#.*/','',$l)); if($l===''||strpos($l,'=')===false) continue;
    list($k,$v) = explode('=',$l,2); $k=trim($k); $v=trim($v);
    if(preg_match('/^CHAN(\d)$/',$k,$m)){ $p=explode(';',$v); $chan[(int)$m[1]]=['src'=>$p[0]??'max','curve'=>$p[1]??'','floor'=>$p[2]??60]; }
    else $cfg[$k]=$v;
  }
}
function sel($a,$b){ return $a===$b?'selected':''; }
?>
