<script>
const AFU = "/plugins/auralis-fan/auralis-fan.php";
function afShow(id,v,unit){ const e=document.getElementById(id); if(e) e.textContent=(v===null||v===undefined?'–':v)+(unit||''); }
function afPoll(){
  fetch(AFU+"?action=status").then(r=>r.json()).then(d=>{
    if(!d.ok) return;
    const r=document.getElementById('af-running');
    r.textContent = d.running?'läuft':'gestoppt'; r.className='af-run '+(d.running?'af-on':'af-off');
    afShow('t-gpu',d.temps.gpu); afShow('t-cpu',d.temps.cpu); afShow('t-disk',d.temps.disk); afShow('t-nvme',d.temps.nvme);
    (d.fans||[]).forEach(f=>{ afShow('pw'+f.ch, f.pct, '%'); afShow('rp'+f.ch, f.rpm); });
    if(d.daemon){ document.getElementById('af-ts').textContent='Daemon: '+d.daemon.ts+(d.daemon.failsafe==1?'  ⚠ FAILSAFE 100%':'');
      (d.daemon.fans||[]).forEach(f=>{ afShow('st'+f.ch, f.srctemp,'°C'); afShow('wt'+f.ch, Math.round(f.want*100/255),'%'); }); }
  }).catch(()=>{});
}
function afSave(){
  const fd=new FormData(document.getElementById('af-form'));
  if(fd.get('mode')==='live' && !confirm('Live-Modus: der Regler steuert jetzt die Lüfter. Fortfahren?')){ return; }
  fd.append('action','save');
  fetch(AFU,{method:'POST',body:fd}).then(r=>r.json()).then(d=>{
    document.getElementById('af-msg').innerHTML = d.ok?'<span class=af-good>gespeichert ('+d.saved+')</span>':'<span class=af-bad>Fehler</span>';
    afPoll();
  });
}
function afCmd(a){
  fetch(AFU+"?action="+a).then(r=>r.json()).then(d=>{
    document.getElementById('af-msg').innerHTML = d.ok?'<span class=af-good>'+a+' ok</span>':'<span class=af-bad>'+a+' fehlgeschlagen</span>';
    setTimeout(afPoll,600);
  });
}
afPoll(); setInterval(afPoll,3000);
</script>
